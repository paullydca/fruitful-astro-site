<section id="seo-roadmap" class="w-full bg-offWhite py-24 lg:py-32" data-animate="fade-in">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="opacity-0" data-animate="slide-left">
        <span class="text-sm font-semibold text-primary tracking-wider uppercase">SEO Roadmap</span>
        <h2 class="mt-4 font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">Your custom Halifax SEO strategy, built to rank</h2>
        <p class="mt-4 text-lg text-body leading-relaxed">See exactly which keywords to target, which pages to fix, and how your Halifax business climbs to the top of Google, all mapped out in a clear, actionable SEO roadmap.</p>
        <ul class="mt-6 space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg>
            <span class="text-base text-body">A custom keyword map targeting high-intent Halifax search terms your customers actually use.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg>
            <span class="text-base text-body">Prioritized action plan covering technical fixes, content gaps, and link opportunities.</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg>
            <span class="text-base text-body">Clear milestones and projected timelines for hitting page-one rankings.</span>
          </li>
        </ul>
        <a href="/free-seo-audit" class="inline-block mt-8 bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">Get Started</a>
      </div>

      <div class="opacity-0 flex justify-center" data-animate="slide-right">
        <div class="relative animate-float">
          <img src="/images/money-map-app.jpg" alt="SEO Roadmap Dashboard" class="w-[280px] sm:w-[320px] rounded-3xl shadow-[0_20px_60px_rgba(0,0,0,0.12)]" style="transform: rotate(-3deg);" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>
