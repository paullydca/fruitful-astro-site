---
---

<section id="testimonials" class="relative w-full py-24 lg:py-32 overflow-hidden">
  <div class="absolute inset-0 bg-cover bg-center" style="background-image: url(/images/testimonial-bg.jpg);"></div>
  <div class="absolute inset-0 bg-forest-dark/60"></div>

  <div class="relative z-10 max-w-[1200px] mx-auto px-6">
    <div class="mb-8 opacity-0" data-animate="fade-up">
      <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-md rounded-lg px-4 py-2">
        <span class="text-sm font-semibold text-white">Excellent 4.9 out of 5 on</span>
        <div class="flex items-center gap-1">
          <svg class="w-4 h-4 fill-[#157A4E] text-[#157A4E]" viewBox="0 0 24 24" fill="#157A4E"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.402 8.168L12 18.897 4.664 23.165l1.402-8.168L.132 9.21l8.2-1.192z"/></svg>
          <span class="text-sm font-semibold text-[#157A4E]">Google Reviews</span>
        </div>
        <svg class="w-4 h-4 text-white/60" viewBox="0 0 24 24" fill="none"><path d="M13 7h8M13 12h8M13 17h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </div>

      <h2 class="mt-6 font-display font-bold text-[40px] sm:text-[56px] text-white leading-[1.1]">Real Halifax businesses. Real rankings.</h2>
      <p class="mt-4 text-lg text-white/90 max-w-[500px]">Halifax business owners trust SEO Juice to get them found, drive traffic, and grow revenue.</p>
      <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="inline-block mt-6 bg-white hover:bg-white/90 text-primary font-semibold text-sm px-6 py-3 rounded-lg">Get your free SEO audit</a>
    </div>

    <div class="flex flex-col gap-6 mt-12">
      <!-- Reviews block: simplified static markup -->
      <div class="rounded-2xl p-6 shadow-card bg-white opacity-0" data-animate="fade-up">
        <div class="flex items-center gap-2 mb-3">
          <svg class="w-4 h-4 fill-[#157A4E]" viewBox="0 0 24 24" fill="#157A4E"><path d="M12 .587l3.668 7.431 8.2 1.192-5.934 5.787 1.402 8.168L12 18.897 4.664 23.165l1.402-8.168L.132 9.21l8.2-1.192z"/></svg>
          <span class="text-sm font-semibold text-[#1A1A1A] ml-2">Marcus T., Halifax Restaurant Owner</span>
        </div>
        <h4 class="font-display font-bold text-lg text-[#1A1A1A] mb-2">From page 4 to position #1 in 3 months!</h4>
        <p class="text-sm text-body leading-relaxed">SEO Juice completely transformed our online presence. We were invisible on Google. Now we're the first result when people search for restaurants in Halifax. Bookings are up 60% and we haven't spent a cent on ads...</p>
        <button class="mt-3 text-sm font-medium text-primary" data-expand-button>Read more</button>
      </div>
    </div>

    <p class="mt-12 text-xs text-white/60 max-w-[700px]">Client results vary based on industry, competition, and market conditions. Reviews are from real SEO Juice clients and were not compensated. Rankings and traffic results are not guaranteed.</p>
  </div>
</section>
