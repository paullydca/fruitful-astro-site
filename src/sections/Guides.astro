---
---

<section id="team" class="w-full bg-white py-24 lg:py-32">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="font-display font-bold text-[40px] sm:text-[56px] text-[#1A1A1A] leading-[1.1] tracking-[-0.02em]">
        Your dedicated Halifax SEO strategist
      </h2>
      <p class="mt-4 text-lg text-body max-w-[600px] mx-auto">
        Every client gets a dedicated SEO strategist, not a junior account manager, who knows Halifax, knows your industry, and drives real results.
      </p>
      <div class="mt-8 flex justify-center">
        <a href="/free-seo-audit" class="bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">
          Get your strategist
        </a>
      </div>
    </div>

    <div class="mt-16 rounded-2xl overflow-hidden shadow-card">
      <img src="/images/guide-section-bg.jpg" alt="SEO Juice Halifax team" class="w-full h-[250px] sm:h-[300px] object-cover" loading="lazy" />
    </div>

    <div class="mt-12 relative" data-carousel-container>
      <button
        type="button"
        data-carousel-button="left"
        class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white rounded-full shadow-card flex items-center justify-center hover:shadow-card-hover transition-shadow"
        aria-label="Scroll left"
      >
        <span class="text-[#1A1A1A] text-xl">‹</span>
      </button>

      <div
        data-carousel
        class="flex gap-6 overflow-x-auto scrollbar-hide px-12 py-4"
        style="scrollbar-width: none; ms-overflow-style: none;"
      >
        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-borderLight group-hover:border-borderGray border-[3px] transition-colors">
            <img src="/images/guide-1.jpg" alt="Naima Bush" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">Naima Bush</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📍 Local SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🗺️ Google Maps</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📣 Outreach</span>
          </div>
        </div>

        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-borderLight group-hover:border-borderGray border-[3px] transition-colors">
            <img src="/images/guide-2.jpg" alt="Matt Becker" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">Matt Becker</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">⚙️ Technical SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🔗 Link Building</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📊 Analytics</span>
          </div>
        </div>

        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-primary border-[3px] transition-colors">
            <img src="/images/guide-3.jpg" alt="Bri Sullivan" class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute top-2 right-2 bg-primary text-white text-[10px] font-semibold px-2 py-0.5 rounded-full flex items-center gap-0.5">
              ✓
            </div>
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">Bri Sullivan</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">✍️ Content SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">✅ On-Page</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🤝 Strategy</span>
          </div>
          <p class="mt-2 text-xs font-medium text-primary">Bri, Lead Strategist</p>
        </div>

        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-borderLight group-hover:border-borderGray border-[3px] transition-colors">
            <img src="/images/guide-4.jpg" alt="Colin Bishop" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">Colin Bishop</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🛒 eCommerce SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🔗 Link Building</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📚 Research</span>
          </div>
        </div>

        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-borderLight group-hover:border-borderGray border-[3px] transition-colors">
            <img src="/images/guide-5.jpg" alt="Sarah Chen" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">Sarah Chen</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📍 Local SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">✅ On-Page</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📊 Reporting</span>
          </div>
        </div>

        <div class="flex-shrink-0 w-[200px] text-center group">
          <div class="relative mx-auto w-[160px] h-[160px] rounded-full overflow-hidden border-borderLight group-hover:border-borderGray border-[3px] transition-colors">
            <img src="/images/guide-6.jpg" alt="David Park" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <h4 class="mt-4 font-semibold text-base text-[#1A1A1A]">David Park</h4>
          <div class="mt-2 flex flex-wrap justify-center gap-1.5">
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">⚙️ Technical SEO</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">🔍 Keyword Research</span>
            <span class="inline-flex items-center gap-1 bg-bgGray rounded-full px-3 py-1 text-xs font-medium text-body">📣 Outreach</span>
          </div>
        </div>
      </div>

      <button
        type="button"
        data-carousel-button="right"
        class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-white rounded-full shadow-card flex items-center justify-center hover:shadow-card-hover transition-shadow"
        aria-label="Scroll right"
      >
        <span class="text-[#1A1A1A] text-xl">›</span>
      </button>
    </div>
  </div>
</section>
