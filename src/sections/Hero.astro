---

<section class="relative min-h-[100dvh] w-full flex items-center justify-center overflow-hidden">
  <video autoPlay muted loop playsInline class="absolute inset-0 w-full h-full object-cover">
    <source src="/videos/hero-video.mp4" type="video/mp4" />
  </video>

  <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(2,42,28,0.7) 0%, rgba(2,42,28,0.3) 50%, rgba(2,42,28,0.8) 100%);"></div>

  <div class="relative z-10 text-center px-6 max-w-[800px] mx-auto">
    <h1 class="font-display font-bold text-white text-[40px] sm:text-[56px] lg:text-[72px] leading-[1.0] tracking-[-0.03em] opacity-0" data-animate="fade-up">Halifax's SEO Agency: Get Found on Google.</h1>

    <p class="mt-6 text-lg sm:text-xl text-white/90 leading-relaxed max-w-[600px] mx-auto opacity-0" data-animate="fade-up">SEO Juice helps Halifax businesses rank higher on Google, drive more organic traffic, and turn clicks into customers, with a dedicated SEO strategist in your corner.</p>

    <div class="mt-8 flex flex-col items-center gap-4 opacity-0" data-animate="fade-up">
      <a href="/free-seo-audit" class="bg-primary hover:bg-primary-hover text-white font-semibold text-base px-8 py-3.5 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-[0_4px_16px_rgba(21,122,78,0.4)]">Get Your Free SEO Audit</a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-0" data-animate="fade-in">
    <svg class="w-6 h-6 text-white/60 animate-bounce" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </div>
</section>
