---
import { withBase } from '../lib/withBase';
---

<section id="results" class="w-full bg-white py-24 lg:py-32">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative flex justify-center opacity-0" data-animate="slide-left">
        <div class="relative">
          <img src={withBase('/images/spend-section-app.jpg')} alt="SEO Rankings Dashboard" class="w-[260px] sm:w-[300px] rounded-3xl shadow-[0_20px_60px_rgba(0,0,0,0.12)]" loading="lazy" />
          <img src={withBase('/images/card-product.jpg')} alt="SEO Results Report" class="absolute -bottom-4 -right-8 w-[180px] sm:w-[220px] rounded-xl shadow-[0_8px_24px_rgba(0,0,0,0.15)]" style="transform: rotate(15deg);" loading="lazy" />
        </div>
      </div>

      <div class="opacity-0" data-animate="slide-right">
        <span class="text-sm font-semibold text-primary tracking-wider uppercase">Proven Results</span>
        <h2 class="mt-4 font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A]">Real rankings. Real traffic. Real Halifax revenue.</h2>
        <p class="mt-4 text-lg text-body leading-relaxed">SEO is the highest-ROI marketing channel for Halifax businesses, and we have the numbers to prove it.</p>
        <ul class="mt-6 space-y-4">
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg><span class="text-base text-body">Average 3.2x ROI: clients earn back more in organic revenue than they spend on SEO within 12 months</span></li>
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg><span class="text-base text-body">Page-one rankings for target Halifax keywords within 90 days for most clients</span></li>
          <li class="flex items-start gap-3"><svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="#157A4E"><path d="M20.285 6.709l-11.025 11.03-5.545-5.548 1.414-1.414 4.131 4.131 9.611-9.616z"/></svg><span class="text-base text-body">100% transparent reporting: monthly keyword rankings, traffic, and lead data</span></li>
        </ul>
        <a href={withBase('/free-seo-audit')} class="inline-block mt-8 bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg">Get Started</a>
      </div>
    </div>
  </div>
</section>
