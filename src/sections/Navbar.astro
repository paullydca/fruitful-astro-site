<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-transparent">
  <div class="max-w-[1200px] mx-auto px-6 h-[72px] flex items-center justify-between">
    <a href={`${import.meta.env.BASE_URL}`} class="flex items-center gap-2">
      <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none"><path d="M3 12h18M12 3v18" stroke="#157A4E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="font-display font-bold text-xl text-white">SEO Juice</span>
    </a>

    <div class="hidden md:flex items-center gap-1">
      <div class="relative group">
        <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">
          Services
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition-opacity">
          <div class="bg-white rounded-xl shadow-dropdown p-3 w-[300px] border border-borderLight">
            <a href={`${import.meta.env.BASE_URL}#how-it-works`} class="block px-4 py-3 rounded-lg hover:bg-bgGray transition-colors">Local SEO Halifax<div class="text-[13px] text-mutedText">Dominate Google Maps & local search results</div></a>
            <a href={`${import.meta.env.BASE_URL}#seo-roadmap`} class="block px-4 py-3 rounded-lg hover:bg-bgGray transition-colors">Technical SEO<div class="text-[13px] text-mutedText">Speed, structure, and site health fixes</div></a>
            <a href={`${import.meta.env.BASE_URL}#results`} class="block px-4 py-3 rounded-lg hover:bg-bgGray transition-colors">Content & Link Building<div class="text-[13px] text-mutedText">Authority-building content that earns rankings</div></a>
          </div>
        </div>
      </div>

      <a href={`${import.meta.env.BASE_URL}#pricing`} class="px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">Pricing</a>

      <div class="relative group">
        <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">
          Compare
          <svg class="w-4 h-4 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition-opacity">
          <div class="bg-white rounded-xl shadow-dropdown p-2 w-[240px] border border-borderLight">
            <a href={`${import.meta.env.BASE_URL}compare/in-house-seo`} class="block px-4 py-2.5 rounded-lg hover:bg-bgGray transition-colors text-sm font-medium text-body">vs In-House SEO</a>
            <a href={`${import.meta.env.BASE_URL}compare/other-agencies`} class="block px-4 py-2.5 rounded-lg hover:bg-bgGray transition-colors text-sm font-medium text-body">vs Other Halifax Agencies</a>
            <a href={`${import.meta.env.BASE_URL}compare/diy-seo`} class="block px-4 py-2.5 rounded-lg hover:bg-bgGray transition-colors text-sm font-medium text-body">vs DIY SEO</a>
          </div>
        </div>
      </div>

      <a href={`${import.meta.env.BASE_URL}blog`} class="px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">Blog</a>
      <a href={`${import.meta.env.BASE_URL}#team`} class="px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">Our Team</a>
      <a href={`${import.meta.env.BASE_URL}#testimonials`} class="px-3 py-2 text-sm font-medium transition-colors rounded-lg text-white/85 hover:text-white hover:bg-white/10">Client Results</a>
    </div>

    <div class="flex items-center gap-4">
      <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="bg-primary hover:bg-primary-hover text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-all">Free SEO Audit</a>
