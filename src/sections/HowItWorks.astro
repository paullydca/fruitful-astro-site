---
---

<section id="how-it-works" class="w-full bg-sage-light">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32">
    <div class="text-center mb-20">
      <h2 class="font-display font-bold text-[40px] sm:text-[56px] text-[#1A1A1A] leading-[1.1] tracking-[-0.02em]">
        How Halifax SEO works
      </h2>
      <p class="mt-4 text-lg text-body max-w-[500px] mx-auto">
        Higher rankings and more organic traffic are closer than you think.
      </p>
    </div>

    <div class="space-y-24 lg:space-y-32">
      <div class="grid grid-cols-1 lg:grid-cols-[45%_55%] gap-12 lg:gap-16 items-center">
        <div class="opacity-0" data-animate="slide-left">
          <div class="flex items-start gap-4">
            <div class="hidden lg:flex flex-col items-center gap-2 pt-1">
              <div class="w-8 h-8 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-sm text-primary">01</span>
              </div>
              <div class="w-0.5 h-24 bg-borderGray" />
            </div>
            <div>
              <span class="lg:hidden font-display font-bold text-sm text-primary tracking-wider">01</span>
              <h3 class="font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
                We audit your website
              </h3>
              <p class="mt-4 text-lg text-body leading-relaxed">
                Your dedicated SEO strategist runs a deep technical and content audit to uncover why you're not ranking in Halifax search results and find your fastest path to page one.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">
                  Get My Free Audit
                </a>
                <a href={`${import.meta.env.BASE_URL}#team`} class="border border-primary text-primary hover:bg-primary-light font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5">
                  Meet our team
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="opacity-0 flex justify-center" data-animate="slide-right">
          <div class="relative rounded-2xl overflow-hidden shadow-card max-w-[700px] w-full">
            <img src={`${import.meta.env.BASE_URL}images/step-1.jpg`} alt="SEO audit process" class="w-full h-auto object-cover" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[55%_45%] gap-12 lg:gap-16 items-center">
        <div class="opacity-0 flex justify-center" data-animate="slide-left">
          <div class="relative rounded-2xl overflow-hidden shadow-card max-w-[700px] w-full">
            <img src={`${import.meta.env.BASE_URL}images/step-2.jpg`} alt="SEO strategy planning" class="w-full h-auto object-cover" loading="lazy" />
          </div>
        </div>

        <div class="opacity-0" data-animate="slide-right">
          <div class="flex items-start gap-4">
            <div class="hidden lg:flex flex-col items-center gap-2 pt-1">
              <div class="w-8 h-8 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-sm text-primary">02</span>
              </div>
              <div class="w-0.5 h-24 bg-borderGray" />
            </div>
            <div>
              <span class="lg:hidden font-display font-bold text-sm text-primary tracking-wider">02</span>
              <h3 class="font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
                We build your SEO strategy
              </h3>
              <p class="mt-4 text-lg text-body leading-relaxed">
                We research the exact keywords Halifax customers use to find businesses like yours, then map out a custom strategy covering on-page SEO, local SEO, content, and link building.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">
                  Get Started
                </a>
                <a href={`${import.meta.env.BASE_URL}#how-it-works`} class="border border-primary text-primary hover:bg-primary-light font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5">
                  See our services
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[45%_55%] gap-12 lg:gap-16 items-center">
        <div class="opacity-0" data-animate="slide-left">
          <div class="flex items-start gap-4">
            <div class="hidden lg:flex flex-col items-center gap-2 pt-1">
              <div class="w-8 h-8 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-sm text-primary">03</span>
              </div>
              <div class="w-0.5 h-24 bg-borderGray" />
            </div>
            <div>
              <span class="lg:hidden font-display font-bold text-sm text-primary tracking-wider">03</span>
              <h3 class="font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
                We execute your SEO roadmap
              </h3>
              <p class="mt-4 text-lg text-body leading-relaxed">
                Our Halifax SEO team handles everything: technical fixes, optimized page content, Google Business Profile, local citations, and authoritative backlinks, so you can focus on running your business.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">
                  Get Started
                </a>
                <a href={`${import.meta.env.BASE_URL}#seo-roadmap`} class="border border-primary text-primary hover:bg-primary-light font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5">
                  See the roadmap
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="opacity-0 flex justify-center" data-animate="slide-right">
          <div class="relative rounded-2xl overflow-hidden shadow-card max-w-[700px] w-full">
            <img src={`${import.meta.env.BASE_URL}images/step-3.jpg`} alt="SEO roadmap execution" class="w-full h-auto object-cover" loading="lazy" />
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[55%_45%] gap-12 lg:gap-16 items-center">
        <div class="opacity-0 flex justify-center" data-animate="slide-left">
          <div class="relative rounded-2xl overflow-hidden shadow-card max-w-[700px] w-full">
            <img src={`${import.meta.env.BASE_URL}images/step-4.jpg`} alt="Improved rankings and traffic" class="w-full h-auto object-cover" loading="lazy" />
          </div>
        </div>

        <div class="opacity-0" data-animate="slide-right">
          <div class="flex items-start gap-4">
            <div class="hidden lg:flex flex-col items-center gap-2 pt-1">
              <div class="w-8 h-8 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-sm text-primary">04</span>
              </div>
            </div>
            <div>
              <span class="lg:hidden font-display font-bold text-sm text-primary tracking-wider">04</span>
              <h3 class="font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
                You rank, traffic grows
              </h3>
              <p class="mt-4 text-lg text-body leading-relaxed">
                Watch your Halifax rankings climb. Every month we send a clear report showing keyword positions, organic traffic growth, and leads generated, then we adjust and push further.
              </p>
              <div class="mt-8 flex flex-wrap gap-3">
                <a href={`${import.meta.env.BASE_URL}free-seo-audit`} class="bg-primary hover:bg-primary-hover text-white font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button">
                  Start Ranking Today
                </a>
                <a href={`${import.meta.env.BASE_URL}#testimonials`} class="border border-primary text-primary hover:bg-primary-light font-semibold text-sm px-6 py-3 rounded-lg transition-all hover:-translate-y-0.5">
                  See client results
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
