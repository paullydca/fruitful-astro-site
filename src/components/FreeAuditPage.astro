---
import { withBase } from '../lib/withBase';
---

<section class="relative w-full pt-32 pb-24 overflow-hidden" style="background: #022A1C;">
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.8) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 48px 48px;"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[360px] rounded-full pointer-events-none" style="background: radial-gradient(ellipse, rgba(21,122,78,0.35) 0%, transparent 70%);"></div>

  <div class="relative z-10 max-w-[860px] mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/15 rounded-full px-4 py-1.5 mb-7 opacity-0" data-animate="fade-up">
      <span class="w-2 h-2 rounded-full bg-primary animate-pulse flex-shrink-0" />
      <span class="text-sm text-white/85 font-medium">Valued at $500, yours completely free</span>
    </div>

    <h1 class="font-display font-bold text-white text-[36px] sm:text-[52px] lg:text-[64px] leading-[1.05] tracking-[-0.03em] opacity-0" data-animate="fade-up" style="text-shadow: 0 2px 30px rgba(0,0,0,0.4);">
      Find out exactly why your Halifax business isn't ranking on Google.
    </h1>

    <p class="mt-6 text-lg sm:text-xl text-white/75 leading-relaxed max-w-[640px] mx-auto opacity-0" data-animate="fade-up">
      Get a comprehensive Halifax SEO audit covering technical health, keyword gaps, competitor analysis, and a prioritised action plan, delivered to your inbox in 3 business days.
    </p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0" data-animate="fade-up">
      <a href="#audit-form" class="bg-primary hover:bg-primary-hover text-white font-semibold text-base px-8 py-4 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-[0_4px_24px_rgba(21,122,78,0.5)] flex items-center gap-2">
        Claim my free SEO audit
        <span class="text-white text-lg">→</span>
      </a>
      <a href="#whats-included" class="text-white/60 hover:text-white/90 text-sm font-medium transition-colors flex items-center gap-1.5">
        See what's included
        <span class="text-lg">↓</span>
      </a>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-6 sm:gap-10 opacity-0" data-animate="fade-up">
      <div class="flex items-center gap-2 text-white/50">
        <span class="w-4 h-4 rounded-full bg-primary flex-shrink-0" />
        <span class="text-sm font-medium">Delivered in 3 business days</span>
      </div>
      <div class="flex items-center gap-2 text-white/50">
        <span class="w-4 h-4 rounded-full bg-primary flex-shrink-0" />
        <span class="text-sm font-medium">50+ Halifax businesses audited</span>
      </div>
      <div class="flex items-center gap-2 text-white/50">
        <span class="w-4 h-4 rounded-full bg-primary flex-shrink-0" />
        <span class="text-sm font-medium">No obligation, ever</span>
      </div>
    </div>
  </div>
</section>

<section id="whats-included" class="w-full bg-white py-24 lg:py-32">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-16 opacity-0" data-animate="fade-up">
      <span class="text-sm font-semibold text-primary tracking-wider uppercase">What you'll receive</span>
      <h2 class="mt-3 font-display font-bold text-[32px] sm:text-[44px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
        Six reports. One complete Halifax SEO picture.
      </h2>
      <p class="mt-4 text-lg text-body max-w-[560px] mx-auto">
        Most Halifax SEO agencies charge $500+ for this. We deliver it free because we believe you should see our value before we ask for anything.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="audit-card opacity-0 bg-primary-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-primary font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Technical SEO Analysis</h3>
        <p class="text-sm text-body leading-relaxed">Site speed, mobile-friendliness, crawlability, Core Web Vitals, and index coverage. Every technical issue holding your rankings back, surfaced and prioritised.</p>
      </div>
      <div class="audit-card opacity-0 bg-lavender-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-lavender font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Keyword Gap Report</h3>
        <p class="text-sm text-body leading-relaxed">The exact Halifax search terms your customers use that you're currently missing: quick wins, high-volume targets, and long-tail opportunities.</p>
      </div>
      <div class="audit-card opacity-0 bg-skyBlue-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-skyBlue font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Competitor Ranking Analysis</h3>
        <p class="text-sm text-body leading-relaxed">See precisely what your top 3 Halifax competitors rank for that you don't, and the gap you need to close to overtake them.</p>
      </div>
      <div class="audit-card opacity-0 bg-terracotta-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-terracotta font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Google Business Profile Review</h3>
        <p class="text-sm text-body leading-relaxed">Map pack readiness, citation consistency across Halifax directories, and your review profile. The cornerstones of local SEO in the HRM.</p>
      </div>
      <div class="audit-card opacity-0 bg-primary-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-primary font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Backlink Profile Assessment</h3>
        <p class="text-sm text-body leading-relaxed">Your current link authority vs. your Halifax competitors, toxic link identification, and the link gaps that matter most for rankings.</p>
      </div>
      <div class="audit-card opacity-0 bg-lavender-light rounded-2xl p-7 hover:shadow-card transition-shadow" data-animate="fade-up">
        <div class="w-11 h-11 rounded-xl bg-white shadow-xs flex items-center justify-center mb-5">
          <span class="text-lavender font-bold">✓</span>
        </div>
        <h3 class="font-display font-bold text-[17px] text-[#1A1A1A] mb-2">Priority Action Plan</h3>
        <p class="text-sm text-body leading-relaxed">A ranked, specific list of fixes and opportunities, from 48-hour quick wins to long-term moves, with estimated impact for each.</p>
      </div>
    </div>
  </div>
</section>

<section class="w-full bg-sage-light py-16">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="text-center">
        <div class="text-primary text-3xl font-bold mb-3">50+</div>
        <p class="text-sm text-body leading-snug">Halifax businesses audited</p>
      </div>
      <div class="text-center">
        <div class="text-primary text-3xl font-bold mb-3">94%</div>
        <p class="text-sm text-body leading-snug">See results within 90 days</p>
      </div>
      <div class="text-center">
        <div class="text-primary text-3xl font-bold mb-3">4.9 / 5</div>
        <p class="text-sm text-body leading-snug">Google review rating</p>
      </div>
      <div class="text-center">
        <div class="text-primary text-3xl font-bold mb-3">3.2×</div>
        <p class="text-sm text-body leading-snug">Average ROI in year one</p>
      </div>
    </div>
  </div>
</section>

<section id="audit-form" class="w-full py-24 lg:py-32" style="background: linear-gradient(180deg, #E8F5EE 0%, #F0F7F3 60%, #FFFFFF 100%);">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid grid-cols-1 lg:grid-cols-[44%_56%] gap-12 lg:gap-20 items-start">
      <div>
        <span class="text-sm font-semibold text-primary tracking-wider uppercase">What happens next</span>
        <h2 class="mt-3 font-display font-bold text-[28px] sm:text-[36px] text-[#1A1A1A] leading-[1.2] tracking-[-0.02em]">
          Submit today and get your audit by the end of the week.
        </h2>
        <p class="mt-4 text-base text-body leading-relaxed">
          No automated tools. No generic checklists. Every audit is researched and written by an actual Halifax SEO strategist who knows your market.
        </p>

        <div class="mt-8 space-y-1">
          <div class="flex gap-5">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-9 h-9 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-xs text-primary">01</span>
              </div>
              <div class="w-0.5 h-10 bg-borderLight mt-1" />
            </div>
            <div class="pb-8">
              <h4 class="font-semibold text-[#1A1A1A]">We review your submission</h4>
              <p class="mt-1 text-sm text-body leading-relaxed">A real SEO strategist (not a bot) reviews your website and business within 24 hours.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-9 h-9 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-xs text-primary">02</span>
              </div>
              <div class="w-0.5 h-10 bg-borderLight mt-1" />
            </div>
            <div class="pb-8">
              <h4 class="font-semibold text-[#1A1A1A]">We run your full audit</h4>
              <p class="mt-1 text-sm text-body leading-relaxed">We research your Halifax competitive landscape and compile all six audit reports. Takes 2–3 business days.</p>
            </div>
          </div>
          <div class="flex gap-5">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-9 h-9 rounded-full bg-primary-light flex items-center justify-center">
                <span class="font-display font-bold text-xs text-primary">03</span>
              </div>
            </div>
            <div class="pb-8">
              <h4 class="font-semibold text-[#1A1A1A]">We present the findings</h4>
              <p class="mt-1 text-sm text-body leading-relaxed">We deliver a clear, actionable report and invite you to a free 30-min strategy call. Zero sales pressure.</p>
            </div>
          </div>
        </div>

        <div class="mt-2 bg-white rounded-2xl p-6 shadow-card border border-borderLight">
          <div class="flex gap-0.5 mb-3">★★★★★</div>
          <p class="text-sm text-body italic leading-relaxed">
            "The free audit alone was worth a conversation. They found three technical issues our previous agency missed entirely. We signed up the same week."
          </p>
          <p class="mt-3 text-sm font-semibold text-[#1A1A1A]">Marcus T., Halifax Restaurant Owner</p>
        </div>
      </div>

      <div class="bg-white rounded-3xl shadow-[0_8px_48px_rgba(0,0,0,0.09)] p-8 sm:p-10">
        <div data-audit-success class="hidden text-center py-10">
          <div class="w-16 h-16 rounded-full bg-primary-light flex items-center justify-center mx-auto mb-5">
            <span class="text-primary text-3xl">✓</span>
          </div>
          <h3 class="font-display font-bold text-2xl text-[#1A1A1A] mb-3">You're on the list!</h3>
          <p class="text-body leading-relaxed max-w-[340px] mx-auto">
            We'll review your submission and get started on your Halifax SEO audit. Expect to hear from us within <strong>24 hours</strong>.
          </p>
          <p class="mt-5 text-sm text-body">
            While you wait, see <a href={withBase('/#testimonials')} class="text-primary hover:underline font-medium">what Halifax businesses say about working with us</a>.
          </p>
        </div>

        <form data-audit-form class="space-y-4">
          <div class="mb-7">
            <h3 class="font-display font-bold text-[22px] text-[#1A1A1A]">Claim your free Halifax SEO audit</h3>
            <p class="mt-1.5 text-sm text-body">Takes 60 seconds. Delivered in 3 business days. No obligation.</p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Your name</span>
              <input type="text" name="firstName" required class="mt-2 w-full rounded-2xl border border-borderLight px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Business name</span>
              <input type="text" name="businessName" required class="mt-2 w-full rounded-2xl border border-borderLight px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </label>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Website</span>
              <input type="url" name="website" class="mt-2 w-full rounded-2xl border border-borderLight px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Email</span>
              <input type="email" name="email" required class="mt-2 w-full rounded-2xl border border-borderLight px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </label>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Phone</span>
              <input type="tel" name="phone" class="mt-2 w-full rounded-2xl border border-borderLight px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10" />
            </label>
            <label class="block">
              <span class="text-sm font-semibold text-[#1A1A1A]">Primary challenge</span>
              <select name="challenge" required class="mt-2 w-full rounded-2xl border border-borderLight bg-white px-4 py-3 text-body outline-none focus:border-primary focus:ring-2 focus:ring-primary/10">
                <option value="">Choose one</option>
                <option value="rankings">Rankings</option>
                <option value="traffic">Traffic</option>
                <option value="leads">Leads</option>
                <option value="visibility">Local visibility</option>
                <option value="other">Other</option>
              </select>
            </label>
          </div>

          <button type="submit" class="w-full mt-2 bg-forest-dark hover:bg-[#054D33] text-white font-semibold text-base py-4 rounded-xl transition-all hover:-translate-y-0.5 flex items-center justify-center gap-2.5">
            Send my free audit request
            <span class="text-xl">→</span>
          </button>

          <div class="flex items-center justify-center gap-5 pt-1 text-lightGray text-xs">
            <span>🔒 Secure</span>
            <span>✔ No spam</span>
            <span>🧾 No credit card</span>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<section class="w-full bg-white py-20 lg:py-24">
  <div class="max-w-[1200px] mx-auto px-6">
    <p class="text-center text-sm font-semibold text-primary tracking-wider uppercase mb-10">What Halifax business owners say</p>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="rounded-2xl p-7 border border-borderLight shadow-card bg-white">
        <div class="flex gap-0.5 mb-4">★★★★★</div>
        <p class="text-sm text-body leading-relaxed italic">"From page 4 to position #1 in 3 months. Bookings are up 60% and we haven't spent a cent on ads."</p>
        <div class="mt-5 pt-4 border-t border-borderLight">
          <p class="text-sm font-semibold text-[#1A1A1A]">Marcus T.</p>
          <p class="text-xs text-mutedText">Halifax Restaurant Owner</p>
        </div>
      </div>
      <div class="rounded-2xl p-7 border border-borderLight shadow-card bg-terracotta-light">
        <div class="flex gap-0.5 mb-4">★★★★★</div>
        <p class="text-sm text-body leading-relaxed italic">"We tried two other agencies before SEO Juice. Our organic leads have tripled and we rank for every major legal search term in Halifax."</p>
        <div class="mt-5 pt-4 border-t border-borderLight">
          <p class="text-sm font-semibold text-[#1A1A1A]">Sandra M.</p>
          <p class="text-xs text-mutedText">Dartmouth Law Firm</p>
        </div>
      </div>
      <div class="rounded-2xl p-7 border border-borderLight shadow-card bg-skyBlue-light">
        <div class="flex gap-0.5 mb-4">★★★★★</div>
        <p class="text-sm text-body leading-relaxed italic">"My Google Business Profile hit the top 3 map pack for 'plumber Halifax' within 90 days. I had to hire two more staff."</p>
        <div class="mt-5 pt-4 border-t border-borderLight">
          <p class="text-sm font-semibold text-[#1A1A1A]">Derek L.</p>
          <p class="text-xs text-mutedText">Bedford Home Services</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="w-full bg-sage-light py-24 lg:py-28">
  <div class="max-w-[720px] mx-auto px-6">
    <h2 class="font-display font-bold text-[28px] sm:text-[40px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em] text-center mb-14">Questions about the free audit</h2>
    <div class="bg-white rounded-2xl shadow-card overflow-hidden">
      <div class="border-b border-borderLight">
        <button type="button" data-accordion-trigger class="w-full flex items-center justify-between px-7 py-5 text-left group">
          <span class="text-base font-medium text-[#1A1A1A] pr-4 group-hover:text-primary transition-colors">Is it really free? What's the catch?</span>
          <span class="text-body">⌄</span>
        </button>
        <div class="overflow-hidden transition-all duration-300 max-h-0">
          <p class="px-7 text-sm text-body leading-relaxed">It's genuinely free: no credit card, no obligation, no bait-and-switch. We audit a limited number of Halifax businesses each month because we believe you should see our value before we ask for anything. The audit is yours to keep and act on regardless of whether you ever become a client.</p>
        </div>
      </div>
      <div class="border-b border-borderLight">
        <button type="button" data-accordion-trigger class="w-full flex items-center justify-between px-7 py-5 text-left group">
          <span class="text-base font-medium text-[#1A1A1A] pr-4 group-hover:text-primary transition-colors">How long does the audit take to deliver?</span>
          <span class="text-body">⌄</span>
        </button>
        <div class="overflow-hidden transition-all duration-300 max-h-0">
          <p class="px-7 text-sm text-body leading-relaxed">We deliver your audit within 2–3 business days of receiving your submission. We don't use automated tools that generate a generic PDF in 5 minutes. A real Halifax SEO strategist researches and writes your audit, which takes time done properly.</p>
        </div>
      </div>
      <div class="border-b border-borderLight">
        <button type="button" data-accordion-trigger class="w-full flex items-center justify-between px-7 py-5 text-left group">
          <span class="text-base font-medium text-[#1A1A1A] pr-4 group-hover:text-primary transition-colors">What do you do with my information?</span>
          <span class="text-body">⌄</span>
        </button>
        <div class="overflow-hidden transition-all duration-300 max-h-0">
          <p class="px-7 text-sm text-body leading-relaxed">We use your information only to run your audit and contact you about the results. We never sell, share, or trade your data with anyone. You can opt out of all future communication at any time.</p>
        </div>
      </div>
      <div class="border-b border-borderLight">
        <button type="button" data-accordion-trigger class="w-full flex items-center justify-between px-7 py-5 text-left group">
          <span class="text-base font-medium text-[#1A1A1A] pr-4 group-hover:text-primary transition-colors">What happens after I receive the audit?</span>
          <span class="text-body">⌄</span>
        </button>
        <div class="overflow-hidden transition-all duration-300 max-h-0">
          <p class="px-7 text-sm text-body leading-relaxed">We'll invite you to a free 30-minute strategy call to walk through the findings and answer your questions. You're under no obligation to work with us, though most clients who receive an audit choose to. The strategy call alone is valuable regardless of what you decide.</p>
        </div>
      </div>
      <div>
        <button type="button" data-accordion-trigger class="w-full flex items-center justify-between px-7 py-5 text-left group">
          <span class="text-base font-medium text-[#1A1A1A] pr-4 group-hover:text-primary transition-colors">What if I'm not in Halifax proper?</span>
          <span class="text-body">⌄</span>
        </button>
        <div class="overflow-hidden transition-all duration-300 max-h-0">
          <p class="px-7 text-sm text-body leading-relaxed">No problem. We work with businesses across the Halifax Regional Municipality (HRM) including Dartmouth, Bedford, Sackville, Cole Harbour, and Timberlea, as well as across Nova Scotia. If your customers are searching in the Halifax area, we can help you reach them.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="w-full py-20" style="background: #022A1C;">
  <div class="max-w-[680px] mx-auto px-6 text-center">
    <div class="flex justify-center gap-1 mb-5">★★★★★</div>
    <h2 class="font-display font-bold text-[26px] sm:text-[36px] text-white leading-[1.15] tracking-[-0.02em]">Stop ranking on page two. Let us handle the hard part.</h2>
    <p class="mt-4 text-base max-w-[440px] mx-auto leading-relaxed text-white/75">Free Halifax SEO audit in 3 business days. See exactly what it will take to reach page one.</p>
    <a href={withBase('/free-seo-audit')} class="inline-flex items-center gap-2 mt-8 bg-primary hover:bg-primary-hover text-white font-semibold text-base px-8 py-4 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-[0_4px_24px_rgba(21,122,78,0.5)]">
      Get my free Halifax SEO audit
      <span class="text-white text-lg">→</span>
    </a>
    <p class="mt-4 text-xs text-white/40">Free, no obligation, delivered in 3 business days.</p>
  </div>
</section>

<script>
  (function () {
    const form = document.querySelector('[data-audit-form]') as HTMLFormElement | null;
    const success = document.querySelector('[data-audit-success]') as HTMLElement | null;
    if (!form || !success) return;

    const button = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const defaultLabel = button ? button.innerHTML : '';

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      if (button) {
        button.disabled = true;
        button.innerHTML = 'Sending…';
      }
      setTimeout(() => {
        form.classList.add('hidden');
        success.classList.remove('hidden');
        if (button) {
          button.disabled = false;
          button.innerHTML = defaultLabel;
        }
      }, 1200);
    });
  })();
