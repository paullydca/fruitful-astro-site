---
import { withBase } from '../../lib/withBase';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-CA', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Layout
  title="Halifax SEO Blog | Tips, Guides & Local SEO Insights | SEO Juice"
  description="The SEO Juice blog: actionable SEO tips, Halifax local search guides, and case studies for Nova Scotia businesses that want to rank higher on Google."
>
  <main class="min-h-screen bg-offWhite">
    <!-- Hero -->
    <section class="relative w-full pt-32 pb-20" style="background: #022A1C;">
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.8) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.8) 1px, transparent 1px); background-size: 48px 48px;"
      />
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] rounded-full pointer-events-none"
        style="background: radial-gradient(ellipse, rgba(21,122,78,0.3) 0%, transparent 70%);"
      />
      <div class="relative z-10 max-w-[820px] mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 rounded-full bg-primary flex-shrink-0"></span>
          <span class="text-sm text-white/85 font-medium">Halifax SEO Blog</span>
        </div>
        <h1 class="font-display font-bold text-white text-[36px] sm:text-[52px] leading-[1.08] tracking-[-0.03em]">
          SEO insights for Halifax businesses
        </h1>
        <p class="mt-5 text-lg text-white/70 max-w-[560px] mx-auto leading-relaxed">
          Practical guides, local search strategies, and real data from the Halifax market — written by the SEO Juice team.
        </p>
      </div>
    </section>

    <!-- Posts grid -->
    <section class="w-full py-20 lg:py-24">
      <div class="max-w-[1200px] mx-auto px-6">
        {posts.length === 0 ? (
          <p class="text-center text-body text-lg">Posts coming soon — check back shortly.</p>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((post) => (
              <article class="bg-white rounded-2xl shadow-card border border-borderLight overflow-hidden hover:shadow-card-hover transition-shadow group">
                {post.data.image && (
                  <div class="h-48 overflow-hidden bg-sage-light">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  </div>
                )}
                {!post.data.image && (
                  <div class="h-48 bg-gradient-to-br from-primary-light to-sage-light flex items-center justify-center">
                    <span class="font-display font-bold text-3xl text-primary opacity-30">SEO</span>
                  </div>
                )}
                <div class="p-7">
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-xs font-semibold text-primary tracking-wider uppercase">{post.data.category}</span>
                    <span class="text-xs text-mutedText">{formatDate(post.data.pubDate)}</span>
                  </div>
                  <h2 class="font-display font-bold text-[19px] text-[#1A1A1A] leading-[1.3] tracking-[-0.01em] mb-3 group-hover:text-primary transition-colors">
                    <a href={withBase('/blog/${post.slug}')}>{post.data.title}</a>
                  </h2>
                  <p class="text-sm text-body leading-relaxed line-clamp-3 mb-5">{post.data.description}</p>
                  <a
                    href={withBase('/blog/${post.slug}')}
                    class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary-hover transition-colors"
                  >
                    Read the guide
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                </div>
              </article>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- CTA -->
    <section class="w-full bg-primary-light py-20">
      <div class="max-w-[640px] mx-auto px-6 text-center">
        <h2 class="font-display font-bold text-[26px] sm:text-[34px] text-[#1A1A1A] leading-[1.15] tracking-[-0.02em]">
          Ready to put these strategies to work?
        </h2>
        <p class="mt-4 text-body leading-relaxed">
          Get a free Halifax SEO audit and see exactly where you stand against your competitors.
        </p>
        <a
          href={withBase('/free-seo-audit')}
          class="inline-flex items-center gap-2 mt-7 bg-primary hover:bg-primary-hover text-white font-semibold text-base px-8 py-4 rounded-lg transition-all hover:-translate-y-0.5 hover:shadow-button"
        >
          Get my free SEO audit
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>
